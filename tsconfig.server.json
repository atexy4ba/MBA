{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "rootDir": "src/server",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["node_modules"]
}
